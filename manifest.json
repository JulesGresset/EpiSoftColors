{
  "manifest_version": 3,
  "name": "EpiSoftColors",
  "version": "1.0",
  "description": "Remplace les couleurs vives des intras d'EPITECH par des teintes plus douces.",
  "content_scripts": [
    {
      "matches": ["*://my.epitech.eu/*", "*://*.eval.epitest.eu/*", "*://*.eip.epitech.eu/*"],
      "css": ["styles.css"],
      "js": ["colors.js", "content.js"]
    }
  ],
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "EpiSoftColors"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "episoftcolors@epitech.local",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}